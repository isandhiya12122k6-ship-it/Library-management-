"""
Library Management System
A simple program to manage books, members, and borrowing records.
"""

# ---------- Classes ----------

class Book:
    def __init__(self, book_id, title, author, copies):
        self.book_id = book_id
        self.title = title
        self.author = author
        self.copies = copies
        self.available = copies

    def show(self):
        print(str(self.book_id) + " | " + self.title + " | " + self.author +
              " | Available: " + str(self.available) + "/" + str(self.copies))


class Member:
    def __init__(self, member_id, name):
        self.member_id = member_id
        self.name = name
        self.borrowed_books = []   # list of book_ids this member currently has

    def show(self):
        print(str(self.member_id) + " | " + self.name +
              " | Books borrowed: " + str(len(self.borrowed_books)))


# ---------- Data storage ----------

books = []       # list of Book objects
members = []     # list of Member objects
next_book_id = 1
next_member_id = 1


# ---------- Helper functions ----------

def find_book(book_id):
    for b in books:
        if b.book_id == book_id:
            return b
    return None


def find_member(member_id):
    for m in members:
        if m.member_id == member_id:
            return m
    return None


# ---------- Main features ----------

def add_book():
    global next_book_id
    title = input("Enter book title: ")
    author = input("Enter author name: ")
    copies = int(input("Enter number of copies: "))

    new_book = Book(next_book_id, title, author, copies)
    books.append(new_book)
    next_book_id = next_book_id + 1

    print("Book added successfully!")


def add_member():
    global next_member_id
    name = input("Enter member name: ")

    new_member = Member(next_member_id, name)
    members.append(new_member)
    next_member_id = next_member_id + 1

    print("Member added successfully!")


def issue_book():
    book_id = int(input("Enter book ID: "))
    member_id = int(input("Enter member ID: "))

    book = find_book(book_id)
    member = find_member(member_id)

    if book is None:
        print("Book not found.")
        return

    if member is None:
        print("Member not found.")
        return

    if book.available <= 0:
        print("Sorry, no copies available right now.")
        return

    if len(member.borrowed_books) >= 3:
        print("This member already has 3 books. Cannot issue more.")
        return

    book.available = book.available - 1
    member.borrowed_books.append(book_id)
    print("Book issued to " + member.name + " successfully!")


def return_book():
    book_id = int(input("Enter book ID: "))
    member_id = int(input("Enter member ID: "))

    book = find_book(book_id)
    member = find_member(member_id)

    if book is None:
        print("Book not found.")
        return

    if member is None:
        print("Member not found.")
        return

    if book_id not in member.borrowed_books:
        print(member.name + " does not have this book.")
        return

    member.borrowed_books.remove(book_id)
    book.available = book.available + 1
    print("Book returned successfully!")


def search_book():
    keyword = input("Enter title or author to search: ")
    keyword = keyword.lower()

    found = False
    for b in books:
        if keyword in b.title.lower() or keyword in b.author.lower():
            b.show()
            found = True

    if not found:
        print("No books found matching that search.")


def view_all_books():
    if len(books) == 0:
        print("No books in the library yet.")
        return

    for b in books:
        b.show()


def view_all_members():
    if len(members) == 0:
        print("No members yet.")
        return

    for m in members:
        m.show()


# ---------- Menu ----------

def show_menu():
    print("\n----- LIBRARY MANAGEMENT SYSTEM -----")
    print("1. Add Book")
    print("2. Add Member")
    print("3. Issue Book")
    print("4. Return Book")
    print("5. Search Book (by title/author)")
    print("6. View All Books")
    print("7. View All Members")
    print("8. Exit")


def main():
    while True:
        show_menu()
        choice = input("Enter your choice: ")

        if choice == "1":
            add_book()
        elif choice == "2":
            add_member()
        elif choice == "3":
            issue_book()
        elif choice == "4":
            return_book()
        elif choice == "5":
            search_book()
        elif choice == "6":
            view_all_books()
        elif choice == "7":
            view_all_members()
        elif choice == "8":
            print("Goodbye!")
            break
        else:
            print("Invalid choice, please try again.")


main()
